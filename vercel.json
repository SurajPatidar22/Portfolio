        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"suraj_patidar_resume.pdf\""
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!resume\\.pdf).*)", "destination": "/" }
  ]
